<Window x:Class="Editor.Components.Lobby.SplashLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading"
        Width="1280" Height="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#0D0D0F">
    <Grid>

        <!-- Splash image fills the window -->
        <Image x:Name="SplashImage"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Bottom gradient overlay for text legibility -->
        <Rectangle VerticalAlignment="Bottom" Height="160">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Bottom-right: status message + percentage -->
        <StackPanel VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,36,32">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="White"
                       FontSize="13"
                       Opacity="0.72"
                       HorizontalAlignment="Right"
                       FontFamily="Segoe UI"/>
            <TextBlock x:Name="PercentTextBlock"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right"
                       Margin="0,6,0,0"
                       FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Bottom-left: engine branding -->
        <StackPanel VerticalAlignment="Bottom"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Margin="32,0,0,34">
            <Image x:Name="BrandLogo"
                   Width="22" Height="22"
                   Stretch="Uniform"
                   Opacity="0.55"/>
            <TextBlock Text="Hibou Engine"
                       Foreground="White"
                       Opacity="0.38"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"
                       Margin="9,0,0,0"/>
        </StackPanel>

    </Grid>
</Window>
