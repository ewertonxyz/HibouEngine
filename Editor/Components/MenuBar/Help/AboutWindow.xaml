<Window x:Class="Editor.Components.TopMenu.Help.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Hibou Engine" 
        Height="300" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#2E2E2E"
            BorderBrush="Black" 
            BorderThickness="1" 
            CornerRadius="5">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#1E1E1E">
                <TextBlock Text="About Hibou Engine" 
                           Foreground="WhiteSmoke" 
                           FontFamily="FiraCode"
                           FontWeight="Bold"
                           Margin="15,10"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="20" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Image Source="../Assets/Icons/logo.png" Width="48" Height="48" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="HIBOU ENGINE" 
                                   FontSize="24" 
                                   Foreground="WhiteSmoke" 
                                   FontFamily="FiraCode" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Version 0.0.1 Alpha" 
                                   FontSize="12" 
                                   Foreground="WhiteSmoke" 
                                   FontFamily="FiraCode"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="A custom game engine for study purposes." 
                           HorizontalAlignment="Center"
                           Foreground="WhiteSmoke" 
                           FontFamily="FiraCode"
                           TextWrapping="Wrap" 
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="© 2026 Hibou Dev Team. All rights reserved." 
                           HorizontalAlignment="Center"
                           FontSize="10"
                           Foreground="WhiteSmoke" 
                           FontFamily="FiraCode"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Content="OK" 
                        Background="#1D1D1D"
                        Foreground="WhiteSmoke"
                        BorderBrush="Gray"
                        Click="OkButton_Click"
                        Width="80"
                        IsDefault="True"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>