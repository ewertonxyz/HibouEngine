<UserControl x:Class="Editor.Components.Lobby.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>

        <!-- Dark text box -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background"      Value="#1A1A1A"/>
            <Setter Property="Foreground"      Value="WhiteSmoke"/>
            <Setter Property="CaretBrush"      Value="WhiteSmoke"/>
            <Setter Property="SelectionBrush"  Value="#7C3AED"/>
            <Setter Property="BorderBrush"     Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#585858"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="Root" Property="Background"  Value="#1A1028"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar nav item -->
        <Style x:Key="NavItemStyle" TargetType="{x:Type Button}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Padding"         Value="18,0,18,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="WhiteSmoke"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav item -->
        <Style x:Key="NavItemActiveStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource NavItemStyle}">
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="#222222"
                                BorderThickness="3,0,0,0"
                                BorderBrush="#7C3AED"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary filled accent button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background"      Value="#7C3AED"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#5B21B6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Project list -->
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Margin"                     Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Row"
                                Background="Transparent"
                                BorderBrush="#242424"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#252528"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#2A2040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  SIDEBAR                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Branding -->
                <StackPanel Margin="18,24,18,24">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="../Assets/Icons/logo.png" Width="32" Height="32" Stretch="Uniform"/>
                        <TextBlock Text="Hibou Engine"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Project Hub"
                               Foreground="#444444"
                               FontSize="10"
                               Margin="42,4,0,0"/>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavItemActiveStyle}" Content="Projects"/>
                </StackPanel>

                <!-- Bottom panel -->
                <Border Grid.Row="2"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,1,0,0"
                        Padding="18,16,18,20">
                    <StackPanel>
                        <TextBlock Text="PROJECTS ROOT"
                                   Foreground="#444444"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding ProjectsRootPath}"
                                   Foreground="#666666"
                                   FontSize="10"
                                   TextWrapping="Wrap"/>
                        <Button Style="{StaticResource DarkButtonStyle}"
                                Content="Refresh"
                                Margin="0,14,0,0"
                                HorizontalAlignment="Stretch"
                                Click="Refresh_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  CONTENT AREA                                                      -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">

            <!-- ── PROJECTS VIEW ─────────────────────────────────────────── -->
            <Grid Visibility="{Binding ProjectsViewVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="32,28,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Projects"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="WhiteSmoke"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#555555"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="+ New project"
                            Click="ShowNewProject_Click"/>
                </Grid>

                <!-- Column headers -->
                <Border Grid.Row="1"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,0,0,1"
                        Margin="32,20,32,0"
                        Padding="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Name"
                                   Foreground="#555555" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Location"
                                   Foreground="#555555" FontSize="11" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <!-- Projects list -->
                <ListBox Grid.Row="2"
                         Margin="32,0,32,24"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         MouseDoubleClick="Projects_DoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="64">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="240"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="36" Height="36"
                                        CornerRadius="6"
                                        Background="#1A1A1A"
                                        BorderBrush="#333333"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="WhiteSmoke"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="#666666"
                                               FontSize="11"
                                               Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ProjectFilePath}"
                                           Foreground="#4A4A4A"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,16,0"/>

                                <Button Grid.Column="3"
                                        Style="{StaticResource DarkButtonStyle}"
                                        Content="Open"
                                        Width="80"
                                        VerticalAlignment="Center"
                                        Tag="{Binding}"
                                        Click="OpenCard_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- ── NEW PROJECT VIEW ──────────────────────────────────────── -->
            <Grid Visibility="{Binding NewProjectViewVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="32,28,32,0">
                    <Button Style="{StaticResource DarkButtonStyle}"
                            Content="&#8592; Back"
                            Click="BackToProjects_Click"/>
                    <TextBlock Text="New project"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="WhiteSmoke"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Row="1" Height="1" Background="#2A2A2A" Margin="32,20,32,0"/>

                <!-- Two-column layout -->
                <Grid Grid.Row="2" Margin="32,24,32,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Template picker -->
                    <Grid Margin="0,0,24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Templates"
                                   Foreground="#888888"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="#7C3AED" CornerRadius="4" Padding="14,6">
                                <TextBlock Text="All" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                            <Border Background="Transparent" CornerRadius="4" Padding="14,6" Margin="6,0,0,0" Cursor="Hand">
                                <TextBlock Text="Core" Foreground="#666666" FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <WrapPanel Orientation="Horizontal">
                                <!-- Blank Project card -->
                                <Border Width="140" Height="130"
                                        Background="#252526"
                                        BorderBrush="#7C3AED"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        Margin="0,0,12,12"
                                        Cursor="Hand">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                        <Border Width="60" Height="50"
                                                Background="#2A2040"
                                                CornerRadius="6"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="&#9633;"
                                                       FontSize="28"
                                                       Foreground="#7C3AED"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Blank Project"
                                                   Foreground="WhiteSmoke"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Settings panel -->
                    <Border Grid.Column="1"
                            Background="#1A1A1A"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1,0,0,0"
                            Padding="24,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <TextBlock Text="Blank Project"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="WhiteSmoke"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="A minimal empty project with no pre-configured assets."
                                           Foreground="#555555"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,28"/>

                                <TextBlock Text="Project name"
                                           Foreground="#BBBBBB"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding CreateProjectName, UpdateSourceTrigger=PropertyChanged}"
                                         BorderBrush="{Binding CreateNameBorderBrush}"/>
                                <TextBlock Text="{Binding CreateNameError}"
                                           Foreground="#FF6B6B"
                                           FontSize="11"
                                           Margin="2,5,0,0"
                                           Visibility="{Binding CreateNameErrorVisibility}"/>
                                <TextBlock Text="{Binding CreateFolderName, StringFormat='Folder: {0}'}"
                                           Foreground="#555555"
                                           FontSize="11"
                                           Margin="2,4,0,16"/>

                                <TextBlock Text="Description"
                                           Foreground="#BBBBBB"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding CreateProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Height="72"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,20"/>

                                <TextBlock Text="Location"
                                           Foreground="#BBBBBB"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <Border Background="#141414"
                                        BorderBrush="#333333"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10,8">
                                    <TextBlock Text="{Binding ProjectsRootPath}"
                                               Foreground="#666666"
                                               FontSize="11"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <Border Height="1" Background="#2A2A2A" Margin="0,24,0,20"/>

                                <TextBlock Text="Images"
                                           Foreground="#BBBBBB"
                                           FontSize="12"
                                           Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,20,0">
                                        <Button Width="72" Height="72"
                                                Padding="3"
                                                Style="{StaticResource DarkButtonStyle}"
                                                ToolTip="Click to change logo"
                                                Click="BrowseLogo_Click">
                                            <Image Source="{Binding CreateLogoPreview}" Stretch="Uniform"/>
                                        </Button>
                                        <TextBlock Text="Logo"
                                                   Foreground="#777777"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding CreateLogoError}"
                                                   Foreground="#FF6B6B"
                                                   FontSize="10"
                                                   MaxWidth="76"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding CreateLogoErrorVisibility}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Button Width="128" Height="72"
                                                Padding="3"
                                                Style="{StaticResource DarkButtonStyle}"
                                                ToolTip="Click to change splash screen"
                                                Click="BrowseSplash_Click">
                                            <Image Source="{Binding CreateSplashPreview}" Stretch="Uniform"/>
                                        </Button>
                                        <TextBlock Text="Splash Screen"
                                                   Foreground="#777777"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding CreateSplashError}"
                                                   Foreground="#FF6B6B"
                                                   FontSize="10"
                                                   MaxWidth="132"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding CreateSplashErrorVisibility}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Content="+ Create project"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,28,0,0"
                                        IsEnabled="{Binding CanCreate}"
                                        Click="CreateProject_Click"/>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
