<Window x:Class="Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:Editor.ViewModels"
        xmlns:topmenu="clr-namespace:Editor.Components.MenuBar"
        xmlns:graph="clr-namespace:Editor.Components.Graph.HaircardFactory"
        xmlns:assets="clr-namespace:Editor.Components.AssetsBrowser"
        xmlns:explorer="clr-namespace:Editor.Components.Explorer"
        xmlns:properties="clr-namespace:Editor.Components.Properties"
        xmlns:dock="https://github.com/Dirkster99/AvalonDock"
        xmlns:dockThemes="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        Title="HibouEngine" Height="720" Width="1280"
        WindowState="Maximized">

    <Window.DataContext>
        <viewmodels:EditorViewModel />
    </Window.DataContext>

    <DockPanel Background="#1E1E1E">
        <topmenu:MenuBarView DockPanel.Dock="Top" />

        <dock:DockingManager Background="#1E1E1E">
            <dock:DockingManager.Theme>
                <dockThemes:Vs2013DarkTheme />
            </dock:DockingManager.Theme>

            <dock:LayoutRoot>
                <dock:LayoutPanel Orientation="Vertical">

                    <!-- ── Main work row ── -->
                    <dock:LayoutPanel Orientation="Horizontal">

                        <!-- Graph Editor — dockable -->
                        <dock:LayoutAnchorablePane DockWidth="2*">
                            <dock:LayoutAnchorable Title="Graph Editor"
                                                   ContentId="GraphEditor"
                                                   CanClose="False">
                                <graph:MainGraphView />
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>

                        <!-- OpenGL Viewport — central document, not dockable -->
                        <dock:LayoutDocumentPane DockWidth="3*">
                            <dock:LayoutDocument Title="Viewport"
                                                 ContentId="Viewport"
                                                 CanClose="False">
                                <Border Margin="10" Background="Black"
                                        BorderBrush="#3E3E42" BorderThickness="1">
                                    <ContentControl x:Name="ViewportHost" />
                                </Border>
                            </dock:LayoutDocument>
                        </dock:LayoutDocumentPane>

                        <!-- Right column: Explorer + Properties stacked vertically -->
                        <dock:LayoutPanel Orientation="Vertical" DockWidth="250">
                            <dock:LayoutAnchorablePane DockHeight="2*">
                                <dock:LayoutAnchorable Title="Scene Explorer"
                                                       ContentId="SceneExplorer"
                                                       CanClose="False">
                                    <explorer:ExplorerView x:Name="SceneExplorer" />
                                </dock:LayoutAnchorable>
                            </dock:LayoutAnchorablePane>
                            <dock:LayoutAnchorablePane DockHeight="3*">
                                <dock:LayoutAnchorable Title="Properties"
                                                       ContentId="Properties"
                                                       CanClose="False">
                                    <properties:PropertyEditorView x:Name="SceneProperties" />
                                </dock:LayoutAnchorable>
                            </dock:LayoutAnchorablePane>
                        </dock:LayoutPanel>

                    </dock:LayoutPanel>

                    <!-- ── Asset Browser — dockable, bottom ── -->
                    <dock:LayoutAnchorablePane DockHeight="200">
                        <dock:LayoutAnchorable Title="Asset Browser"
                                               ContentId="AssetBrowser"
                                               CanClose="False">
                            <assets:AssetBrowserView x:Name="AssetBrowser" />
                        </dock:LayoutAnchorable>
                    </dock:LayoutAnchorablePane>

                </dock:LayoutPanel>
            </dock:LayoutRoot>
        </dock:DockingManager>

    </DockPanel>
</Window>

