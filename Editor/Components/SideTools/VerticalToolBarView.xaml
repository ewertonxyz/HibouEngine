<UserControl x:Class="Editor.Components.SideTools.VerticalToolBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="48" Background="{StaticResource BrushBackgroundLight}">
    <StackPanel Orientation="Vertical">
        <Button Width="48" Height="48" Margin="0" ToolTip="Play" Background="Transparent" BorderThickness="0">
            <Image Source="/Assets/Icons/play.png"/>
        </Button>
        <Button Width="48" Height="48" Margin="0" ToolTip="Pause" Background="Transparent" BorderThickness="0">
            <Image Source="/Assets/Icons/pause.png"/>
        </Button>
        <Button Width="48" Height="48" Margin="0" ToolTip="Stop" Background="Transparent" BorderThickness="0">
            <Image Source="/Assets/Icons/stop.png"/>
        </Button>
        <Button Width="48" Height="48" Margin="0" ToolTip="Simulate" Background="Transparent" BorderThickness="0">
            <Image Source="/Assets/Icons/simulate.png"/>
        </Button>
        <Button Width="48" Height="48" Margin="0" ToolTip="Controller" Background="Transparent" BorderThickness="0">
            <Image Source="/Assets/Icons/controller.png"/>
        </Button>
    </StackPanel>
</UserControl>