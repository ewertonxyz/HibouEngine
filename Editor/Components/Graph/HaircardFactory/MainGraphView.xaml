<UserControl x:Class="Editor.Components.Graph.HaircardFactory.MainGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="https://miroiu.github.io/nodify"
             xmlns:viewmodels="clr-namespace:Editor.ViewModels">

    <nodify:NodifyEditor ItemsSource="{Binding Nodes}" Background="#252526">
        <nodify:NodifyEditor.ItemContainerStyle>
            <Style TargetType="{x:Type nodify:ItemContainer}">
                <Setter Property="Location" Value="{Binding NodeLocation}" />
            </Style>
        </nodify:NodifyEditor.ItemContainerStyle>
        <nodify:NodifyEditor.ItemTemplate>
            <DataTemplate DataType="{x:Type viewmodels:NodeViewModel}">
                <nodify:Node Header="{Binding NodeTitle}" />
            </DataTemplate>
        </nodify:NodifyEditor.ItemTemplate>
    </nodify:NodifyEditor>
</UserControl>