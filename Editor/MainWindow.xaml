<Window x:Class="Editor.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:viewmodels="clr-namespace:Editor.ViewModels"
       xmlns:topmenu="clr-namespace:Editor.Components.MenuBar"
       xmlns:graph="clr-namespace:Editor.Components.Graph.HaircardFactory"
       xmlns:viewport="clr-namespace:Editor.Components.Viewport.OpenGL"
       xmlns:assets="clr-namespace:Editor.Components.AssetsBrowser"
       xmlns:explorer="clr-namespace:Editor.Components.Explorer"
       xmlns:properties="clr-namespace:Editor.Components.Properties"
       Title="HibouEngine" Height="720" Width="1280"
       WindowState="Maximized">

    <Window.DataContext>
        <viewmodels:EditorViewModel />
    </Window.DataContext>

    <DockPanel Background="#1E1E1E">
        <topmenu:MenuBarView DockPanel.Dock="Top" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="200" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Main work area -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"  MinWidth="200"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="3*"  MinWidth="300"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="250" MinWidth="160"/>
                </Grid.ColumnDefinitions>

                <!-- Node graph -->
                <graph:MainGraphView Grid.Column="0"/>

                <!-- Splitter: graph | viewport -->
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                              Background="{StaticResource BrushBorder}"
                              ResizeDirection="Columns"/>

                <!-- 3D viewport -->
                <Border Grid.Column="2" Margin="10" Background="Black"
                        BorderBrush="#3E3E42" BorderThickness="1">
                    <viewport:OpenGLViewportView />
                </Border>

                <!-- Splitter: viewport | right panel -->
                <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch"
                              Background="{StaticResource BrushBorder}"
                              ResizeDirection="Columns"/>

                <!-- Right panel: Explorer (top) + Properties (bottom) -->
                <Grid Grid.Column="4"
                      Background="{StaticResource BrushBackgroundLight}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="80"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="3*" MinHeight="80"/>
                    </Grid.RowDefinitions>

                    <explorer:ExplorerView    x:Name="SceneExplorer"    Grid.Row="0"/>
                    <GridSplitter             Grid.Row="1"
                                              HorizontalAlignment="Stretch"
                                              Background="{StaticResource BrushBorder}"
                                              ResizeDirection="Rows"/>
                    <properties:PropertyEditorView x:Name="SceneProperties" Grid.Row="2"/>
                </Grid>
            </Grid>

            <!-- Splitter: work area | asset browser -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                          Background="#3E3E42" ResizeDirection="Rows"/>

            <assets:AssetBrowserView x:Name="AssetBrowser" Grid.Row="2"/>
        </Grid>
    </DockPanel>
</Window>
