<UserControl x:Class="Editor.Components.AssetsBrowser.AssetBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource BrushBackgroundLight}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="#252525"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <DockPanel>
                <Button x:Name="AddButton"
                        DockPanel.Dock="Left"
                        Content="+"
                        Width="28" Height="26"
                        FontSize="16" FontWeight="Light"
                        Foreground="WhiteSmoke"
                        Background="#3A3A3A"
                        BorderBrush="#555"
                        Margin="0,0,8,0"
                        ToolTip="Add or create items"
                        Click="AddButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="New Folder"       Click="NewFolder_Click"/>
                            <Separator/>
                            <MenuItem Header="Import Asset..."  Click="ImportAsset_Click"/>
                            <Separator/>
                            <MenuItem Header="New Level"        Click="NewLevel_Click"/>
                            <MenuItem Header="New Material"     IsEnabled="False"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Grid DockPanel.Dock="Right" Width="220">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#333"
                             Foreground="WhiteSmoke"
                             CaretBrush="WhiteSmoke"
                             BorderBrush="#555"
                             BorderThickness="1"
                             Padding="26,4,6,4"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Text="&#x1F50D;" FontSize="11" Foreground="#888"
                               Margin="7,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <TextBlock Text="Search assets..." Foreground="#666"
                               Margin="28,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ── Main content ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Folder Tree -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#252525" Padding="8,5">
                    <TextBlock Text="FOLDERS" Foreground="#888" FontSize="10" FontWeight="SemiBold"/>
                </Border>
                <TreeView Grid.Row="1"
                          x:Name="AssetTree"
                          Background="Transparent"
                          BorderThickness="0"
                          ItemsSource="{Binding RootNodes}"
                          SelectedItemChanged="AssetTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                            <Setter Property="Padding" Value="4,3"/>
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushText}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BrushBorder}"/>

            <!-- Asset Grid -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#252525" Padding="8,4">
                    <TextBlock Text="{Binding CurrentPath}" Foreground="#888"
                               FontSize="10" TextTrimming="CharacterEllipsis"/>
                </Border>

                <ListBox Grid.Row="1"
                         x:Name="AssetGrid"
                         ItemsSource="{Binding CurrentItems}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="AssetGrid_SelectionChanged"
                         MouseDoubleClick="AssetGrid_DoubleClick"
                         KeyDown="AssetGrid_KeyDown"
                         PreviewMouseRightButtonDown="AssetGrid_PreviewMouseRightButtonDown">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="8"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Card"
                                                Width="88" Height="100"
                                                Background="#2A2A2A"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Cursor="Hand"
                                                Padding="4">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Rename"     Click="RenameItem_Click"/>
                                                    <MenuItem Header="Properties" Click="ShowProperties_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>

                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <Grid Width="56" Height="56"
                                                      HorizontalAlignment="Center">

                                                    <!-- Colored type icon (fallback) -->
                                                    <Border x:Name="IconBorder"
                                                            Background="{Binding IconBackground}"
                                                            CornerRadius="4">
                                                        <TextBlock Text="{Binding TypeLabel}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>

                                                    <!-- Folder icon (Uniform — no crop) -->
                                                    <Image x:Name="FolderImg"
                                                           Source="{Binding Thumbnail}"
                                                           Stretch="Uniform"
                                                           Visibility="Collapsed"/>

                                                    <!-- Texture thumbnail (UniformToFill — fills card) -->
                                                    <Image x:Name="TextureImg"
                                                           Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           Visibility="Collapsed">
                                                        <Image.Clip>
                                                            <RectangleGeometry Rect="0,0,56,56"
                                                                               RadiusX="4" RadiusY="4"/>
                                                        </Image.Clip>
                                                    </Image>

                                                </Grid>

                                                <!-- Inline edit: TextBlock/TextBox swap -->
                                                <Grid Margin="0,5,0,0">
                                                    <TextBlock x:Name="NameText"
                                                               Text="{Binding Name}"
                                                               Foreground="#CCCCCC"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               MaxWidth="84"/>
                                                    <TextBox x:Name="NameEdit"
                                                             Visibility="Collapsed"
                                                             LostFocus="NameEdit_LostFocus"
                                                             KeyDown="NameEdit_KeyDown"
                                                             Background="#333"
                                                             Foreground="WhiteSmoke"
                                                             BorderBrush="#6A4A9E"
                                                             BorderThickness="1"
                                                             Padding="2,1"
                                                             MaxWidth="84"
                                                             TextAlignment="Center"
                                                             FontSize="10"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <!-- Folder: show folder icon -->
                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                <Setter TargetName="IconBorder" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="FolderImg"  Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <!-- Image: show texture thumbnail -->
                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                <Setter TargetName="IconBorder"  Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="TextureImg"  Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <!-- Inline rename -->
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="NameText" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Card" Property="BorderBrush" Value="#555"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Card" Property="BorderBrush" Value="Purple"/>
                                                <Setter TargetName="Card" Property="Background"  Value="#1A0F22"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="{StaticResource BrushBorder}"/>

            <!-- ── Asset Preview ── -->
            <Grid Grid.Column="4" Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#252525" Padding="8,5">
                    <TextBlock Text="PREVIEW" Foreground="#888" FontSize="10" FontWeight="SemiBold"/>
                </Border>

                <!-- Preview area -->
                <Grid Grid.Row="1">
                    <!-- Placeholder when nothing is selected or type unsupported -->
                    <TextBlock Text="No asset selected"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#444" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Texture preview -->
                    <Image Source="{Binding PreviewImage}"
                           Stretch="Uniform"
                           Margin="8"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>

                <!-- Info footer -->
                <Border Grid.Row="2" Background="#252525"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedAssetItem.Name}"
                                   Foreground="WhiteSmoke"
                                   FontSize="11" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PreviewInfo}"
                                   Foreground="#888"
                                   FontSize="10"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
